# arch-site-model 환경변수 — 복사해서 `.env` 로 저장 후 값 채우기
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# VWorld API 키는 https://www.vworld.kr 에서 발급.
# 테스트 키(VWORLD_TEST_KEY)를 운영 키(VWORLD_KEY)보다 우선 사용한다.

# 테스트(개발) 키 — 있으면 이게 우선.
VWORLD_TEST_KEY=

# 운영 키 — 테스트 키가 비어 있을 때 사용.
VWORLD_KEY=

# VWorld 키 발급 시 등록한 도메인 (API 호출 시 필요).
VWORLD_DOMAIN=

# (선택) 지형 비축 스토어 경로. 기본값 geo_store/
# GEO_STORE=geo_store

# --- 정사영상(orthophoto) 텍스처 (Tier 1) ---
# 소스: "vworld"(기본, 위 VWORLD_KEY 재사용 — 지금 바로 작동)
#       "ngii"(공공누리 1유형, 상업 허용 — 아래 NGII_KEY 발급 후)
# ORTHO_SOURCE=vworld

# NGII 영상지도 WMTS 인증키 — data.go.kr "국토지리정보원_영상지도, 배경지도 API"(15059358)
# 발급 후 채우고 ORTHO_SOURCE=ngii 로 전환.
# NGII_KEY=

# (선택) 정사영상 타일 줌 레벨. 기본 18(≈0.6m/px). 반경 클수록 낮춰 타일 폭주 방지.
# ORTHO_ZOOM=18
