# arch-site-model 환경변수 — 복사해서 `.env` 로 저장 후 값 채우기
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# VWorld API 키는 https://www.vworld.kr 에서 발급.
# 테스트 키(VWORLD_TEST_KEY)를 운영 키(VWORLD_KEY)보다 우선 사용한다.

# 테스트(개발) 키 — 있으면 이게 우선.
VWORLD_TEST_KEY=

# 운영 키 — 테스트 키가 비어 있을 때 사용.
VWORLD_KEY=

# VWorld 키 발급 시 등록한 도메인 (API 호출 시 필요).
VWORLD_DOMAIN=

# (선택) 지형 비축 스토어 경로. 기본값 geo_store/
# GEO_STORE=geo_store
