# 환경변수 (비밀 키)
.env

# 지형 비축 스토어(DEM). manifest.json만 git 추적(작은 index).
# DEM 타일은 GCS 버킷(gs://arch-site-model-dem)에서 /vsicurl 윈도우 읽기로 서빙하므로
# git·이미지에 넣지 않는다(2026-07-03 GCS 전환 완료). 로컬 개발은 geo_store/의 로컬 tif
# 또는 DEM_TILE_BASE=/vsicurl/… 로.
geo_store/*.tif

# 도로 노면 벡터(Phase R). road_manifest.json만 git 추적(작은 index). 지역 GeoJSON은
# DEM 타일과 동일 원칙으로 git·이미지에서 제외(서빙은 추후 GCS, 로컬 개발은 road_bake로 생성).
geo_store/*.geojson

# 출력물 (런타임 생성물 — API 잡 폴더·데모 등)
# 주의: 앞에 / 필수 — 없으면 모든 깊이에서 매치돼 src/output/(코드!)까지 제외되는 사고가
# 남(실제 발생: gcloud run deploy --source 가 .gcloudignore 없으면 .gitignore를 그대로 써서
# 소스 업로드 필터링 → src/output/ 통째로 빠짐 → ModuleNotFoundError: src.output, 2026-07-01).
/output/
*.skp
*.3dm
*.obj
*.gltf
skp_code.py        # generate() 가 뽑는 build_model 코드 (예시/디버그용)

# 프론트엔드 (node_modules는 어느 깊이든 무시, dist는 빌드 산출물)
node_modules/
frontend/dist/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# 테스트/캐시
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE/OS
.vscode/
.idea/
.DS_Store
Thumbs.db
