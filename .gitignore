# 환경변수 (비밀 키)
.env

# 지형 비축 스토어(DEM) — 배포 빌드(Cloud Build)에 필요하므로 추적함.
# 지역 확장으로 용량이 커지면 GCS 버킷 마운트로 전환하고 다시 무시할 것.
# geo_store/

# 출력물 (런타임 생성물 — API 잡 폴더·데모 등)
# 주의: 앞에 / 필수 — 없으면 모든 깊이에서 매치돼 src/output/(코드!)까지 제외되는 사고가
# 남(실제 발생: gcloud run deploy --source 가 .gcloudignore 없으면 .gitignore를 그대로 써서
# 소스 업로드 필터링 → src/output/ 통째로 빠짐 → ModuleNotFoundError: src.output, 2026-07-01).
/output/
*.skp
*.3dm
*.obj
*.gltf
skp_code.py        # generate() 가 뽑는 build_model 코드 (예시/디버그용)

# 프론트엔드 (node_modules는 어느 깊이든 무시, dist는 빌드 산출물)
node_modules/
frontend/dist/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# 테스트/캐시
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE/OS
.vscode/
.idea/
.DS_Store
Thumbs.db
